{
  "AzureConfig": {
    "KeyVaultName": "movieapivault"
  },
  "Settings": {
    "DeleteDatabaseOnBuild": "true"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },

  "FileLocalConfig": {
    "ImageStorageFolder": "/MoviePosters/",
    "ImageStoragePath": "wwwroot\\MoviePosters\\"
  },
  "AllowedHosts": "*"
}